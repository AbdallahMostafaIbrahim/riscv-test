.DS_Store
build/

# Generated at run time by the Makefile: mem/default.hex (or another
# tests/<name>.hex) is copied over this file before each sim.
mem/inst.hex

# Vivado project directory (entirely generated from vivado_project.tcl)
vivado/

# Vivado / xsim runtime junk that lands in the repo root if you
# ever run those tools outside a project folder.
*.jou
*.log
*.str
*.wdb
*.pb
.Xil/
xsim.dir/
