    {
      "id": "QjXgBgmapEzkk0bDjv9Aw",
      "type": "text",
      "x": -43866.05422960782,
      "y": 96640.25108082806,
      "width": 8161.40283203125,
      "height": 2732.3285213887903,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "c0AaV",
      "roundness": null,
      "seed": 622865152,
      "version": 734,
      "versionNonce": 1101394561,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776256687137,
      "link": null,
      "locked": false,
      "text": "1. Create Connector (Inserts into database)\n   a) returns token\n2. Add token to connector config\n3. Connector establishes connection to relay\n    a) starts websocket with relay with token\n    b) sends hello message to relay\n    c) relay authenticates the connector with /verify on the backend\n    d) relay responds with hello_ack\n",
      "fontSize": 242.87364634567027,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Create Connector (Inserts into database)\n   a) returns token\n2. Add token to connector config\n3. Connector establishes connection to relay\n    a) starts websocket with relay with token\n    b) sends hello message to relay\n    c) relay authenticates the connector with /verify on the backend\n    d) relay responds with hello_ack\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
